<Graph fps={30} duration="5s" size={[1280,720]}>
  <Background color="#0b1220" />

  <Scene id="business_barchart_animated_easeinout">
    <Defs>
      <LinearGradient id="bg_glow" x1="0" y1="0" x2="1" y2="1"
                      stops="0:#111c31, 0.55:#0b1220, 1:#09101c" />
      <LinearGradient id="panel_grad" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#182743, 1:#101b30" />
      <LinearGradient id="bar_q1" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#58c6ff, 1:#2f68ff" />
      <LinearGradient id="bar_q2" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#6fe7c6, 1:#1f9b7d" />
      <LinearGradient id="bar_q3" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#ffd277, 1:#ff8a3d" />
      <LinearGradient id="bar_q4" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#f7a5ff, 1:#b25fff" />
      <LinearGradient id="bar_gloss" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#ffffff66, 1:#ffffff00" />
    </Defs>

    <Timeline>
      <Track id="scene_content" space="world" z="0">
        <Sequence from="0s" duration="5s" out="hold">
