              <Text x="190" y="170" value="FY2026 (USD, Millions)" fontFamily="Arial" fontSize="22" color="#a9bddb" />
              <Text x="160" y="560" value="0" fontFamily="Arial" fontSize="20" color="#8ea7c8" />
              <Text x="146" y="500" value="20" fontFamily="Arial" fontSize="20" color="#8ea7c8" />
              <Text x="146" y="440" value="40" fontFamily="Arial" fontSize="20" color="#8ea7c8" />
              <Text x="146" y="380" value="60" fontFamily="Arial" fontSize="20" color="#8ea7c8" />
              <Text x="146" y="320" value="80" fontFamily="Arial" fontSize="20" color="#8ea7c8" />
              <Text x="132" y="260" value="100" fontFamily="Arial" fontSize="20" color="#8ea7c8" />
              <Text x="336" y="598" value="Q1" fontFamily="Arial" fontSize="26" color="#d9e5ff" />
              <Text x="516" y="598" value="Q2" fontFamily="Arial" fontSize="26" color="#d9e5ff" />
              <Text x="696" y="598" value="Q3" fontFamily="Arial" fontSize="26" color="#d9e5ff" />
              <Text x="876" y="598" value="Q4" fontFamily="Arial" fontSize="26" color="#d9e5ff" />
            </Group>

            <Group id="chart_grid" x="0" y="0" opacity="1">
              <Line x1="220" y1="560" x2="1050" y2="560" stroke="#d9e5ff" strokeWidth="3" />
              <Line x1="220" y1="220" x2="220" y2="560" stroke="#d9e5ff" strokeWidth="3" />
              <Line x1="220" y1="500" x2="1050" y2="500" stroke="#9fb5d344" strokeWidth="2" />
              <Line x1="220" y1="440" x2="1050" y2="440" stroke="#9fb5d344" strokeWidth="2" />
              <Line x1="220" y1="380" x2="1050" y2="380" stroke="#9fb5d344" strokeWidth="2" />
              <Line x1="220" y1="320" x2="1050" y2="320" stroke="#9fb5d344" strokeWidth="2" />
              <Line x1="220" y1="260" x2="1050" y2="260" stroke="#9fb5d344" strokeWidth="2" />
