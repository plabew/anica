{
  "schema_version": 1,
  "description": "Anica runtime manifest \u2014 shared versions and licenses, platform-specific overrides for download URLs.",
  "release_base_url": "https://github.com/LOVELYZOMBIEYHO/anica/releases/download",
  "common": {
    "ffmpeg": {
      "version": "8.0.1",
      "license": "LGPL-2.1-or-later",
      "build_flags": "LGPL-only, shared, no-GPL, no-nonfree",
      "enabled_encoders": ["libvpx", "libaom", "libsvtav1", "libopus"],
      "dependencies": [
        {
          "name": "libvpx",
          "license": "BSD-3-Clause"
        },
        {
          "name": "libaom",
          "license": "BSD-2-Clause"
        },
        {
          "name": "libsvtav1",
          "license": "BSD-2-Clause"
        },
        {
          "name": "libopus",
          "license": "BSD-3-Clause"
        }
      ]
    }
  },
  "platforms": {
    "macos": {
      "download_url": "{release_base_url}/anica-runtime-20260610/anica_runtime_macos_20260610.tar.gz"
    },
    "windows": {
      "ffmpeg_version": "8.1",
      "download_url": "{release_base_url}/anica-runtime-20260610/anica_runtime_windows_20260610.tar.gz"
    },
    "linux": {
      "ffmpeg_version": "8.1",
      "download_url": "{release_base_url}/anica-runtime-20260610/anica_runtime_linux_20260610.tar.gz"
    }
  }
}
