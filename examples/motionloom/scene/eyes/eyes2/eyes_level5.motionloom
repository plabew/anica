                    scaleX={curve("0.00:1.00:ease_in_out, 3.00:0.70:ease_in_out")}
                    skewY={curve("0.00:0:ease_in_out, 3.00:-12:ease_in_out")}
                    d="M 280 -106 C 172 -194 26 -232 -146 -196 C -290 -166 -382 -74 -428 20"
