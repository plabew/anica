                      d="M -72 84 L -154 118 L -146 162 L -64 116 Z" />

                <Path id="highlight_top_left_turn"
                      x={curve("0.00:0:ease_in_out, 2.20:-24:ease_in_out, 3.00:-34:ease_in_out")}
                      scaleX={curve("0.00:1.00:ease_in_out, 3.00:0.38:ease_in_out")}
                      skewY={curve("0.00:0:ease_in_out, 3.00:-12:ease_in_out")}
