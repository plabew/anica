                     scaleX={curve("0.00:1.00:ease_in_out, 1.20:0.58:ease_in_out, 2.35:0.22:ease_in_out, 3.00:0.14:ease_in_out")}
                     scaleY={curve("0.00:1.00:ease_in_out, 2.35:1.08:ease_in_out, 3.00:1.10:ease_in_out")}
