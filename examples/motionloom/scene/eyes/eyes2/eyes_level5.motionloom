                <Circle id="turning_cornea_glint"
                        x="-118"
                        y="-68"
                        radius="18"
                        color="#F7F7F7"
                        opacity={curve("0.00:0.54:ease_in_out, 2.20:0.34:ease_in_out, 3.00:0.10:ease_in_out")}
                        scaleX={curve("0.00:1.00:ease_in_out, 3.00:0.22:ease_in_out")}
                        scaleY={curve("0.00:1.00:ease_in_out, 3.00:1.35:ease_in_out")}
                        skewY={curve("0.00:0:ease_in_out, 3.00:-12:ease_in_out")}
