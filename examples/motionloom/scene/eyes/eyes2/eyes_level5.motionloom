                    rotation={curve("0.00:0:ease_in_out, 3.00:-8:ease_in_out")}
                    scaleX={curve("0.00:1.00:ease_in_out, 3.00:0.48:ease_in_out")}
                    skewY={curve("0.00:0:ease_in_out, 3.00:-6:ease_in_out")}
                    transformOriginX="0"
                    transformOriginY="0"
                    x1="-255"
                    y1="0"
                    x2="210"
                    y2="0"
                    stroke="#3F587733"
                    strokeWidth="2"
                    opacity={curve("0.00:0.0:linear, 1.20:0.28:ease_in_out, 3.00:0.18:ease_in_out")} />

              <!-- Polyline transform demo: corner construction marks compress with the turn. -->
              <Polyline id="outer_corner_turn_marks"
                        x={curve("0.00:0:ease_in_out, 3.00:-34:ease_in_out")}
                        y="14"
                        rotation={curve("0.00:0:ease_in_out, 3.00:-6:ease_in_out")}
                        scaleX={curve("0.00:1.00:ease_in_out, 3.00:0.55:ease_in_out")}
                        skewY={curve("0.00:0:ease_in_out, 3.00:-10:ease_in_out")}
                        transformOriginX="-360"
                        transformOriginY="40"
                        points="-360,30 -405,54 -452,70 -398,92 -438,126 -470,164"
