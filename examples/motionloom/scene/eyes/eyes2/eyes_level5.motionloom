<Graph fps={60} duration="3s" size={[1320,768]}>
  <Background color="#ffffff" />

  <Scene id="eyes2_single_eye_left_turn_level5">
    <Defs>
      <LinearGradient id="sclera_soft" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#D3CEE6, 0.30:#F7F7F7, 0.70:#F7F7F7, 1:#ffffff" />

      <LinearGradient id="iris_level1" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#9368C2, 0.54:#9368C2, 0.55:#FB93A6, 0.68:#FB93A6, 0.69:#FEC3A6, 1:#FEC3A6" />

      <LinearGradient id="lid_grey" x1="0" y1="0" x2="0" y2="1"
                      stops="0:#B7C7C7, 0.70:#B7C7C7, 1:#8da0a3" />

      <Brush id="iris_fill_01"
             stroke="none"
             fill="#FB93A6"
             opacity="0.92" />
    </Defs>

    <Timeline>
      <Track id="scene_content" space="world" z="0">
        <Sequence from="0s" duration="3s" out="hold">
          <Layer>

            <Rect x="0" y="0" width="1320" height="768" color="#ffffff" />

            <!-- Rect transform demo: soft stage card bends subtly while the eye turns. -->
            <Rect id="turn_stage_plate"
                  x="400"
                  y="112"
                  width="520"
                  height="530"
                  radius="36"
                  color="#F8FBFF"
                  opacity="0.58"
                  scaleX={curve("0.00:1.00:ease_in_out, 2.30:0.72:ease_in_out, 3.00:0.66:ease_in_out")}
                  skewX={curve("0.00:0:ease_in_out, 2.30:-5:ease_in_out, 3.00:-8:ease_in_out")}
                  transformOriginX="660"
                  transformOriginY="384" />

            <!-- Text transform demo is intentionally faint; it proves Text has the same primitive transform attrs. -->
            <Text id="primitive_transform_caption"
                  value="Level5 primitive transforms"
                  x="46"
                  y="710"
                  fontSize="24"
                  color="#3F5877"
                  opacity="0.18"
                  scaleX={curve("0.00:1.00:linear, 3.00:0.92:ease_in_out")}
                  skewX={curve("0.00:0:linear, 3.00:-7:ease_in_out")}
                  transformOriginX="0"
                  transformOriginY="18" />

            <Character id="single_eye_left_turn"
                       x="660"
                       y="384"
                       rotation={curve("0.00:0:linear, 1.20:-2:ease_in_out, 3.00:-4:ease_in_out")}
                       scale="0.74"
                       scaleX={curve("0.00:1.00:ease_in_out, 1.20:0.62:ease_in_out, 2.35:0.28:ease_in_out, 3.00:0.22:ease_in_out")}
                       scaleY={curve("0.00:1.00:ease_in_out, 2.35:1.05:ease_in_out, 3.00:1.07:ease_in_out")}
                       skewY={curve("0.00:0:ease_in_out, 1.20:-4:ease_in_out, 2.35:-12:ease_in_out, 3.00:-15:ease_in_out")}
                       transformOriginX="0"
                       transformOriginY="20"
                       opacity="1">

              <!-- Path transform demo: sclera has its own x/scale/skew in addition to the outer Character transform. -->
              <Path id="eye_white_left_turn"
                    x={curve("0.00:0:ease_in_out, 2.25:-18:ease_in_out, 3.00:-28:ease_in_out")}
                    scaleX={curve("0.00:1.00:ease_in_out, 2.25:0.92:ease_in_out, 3.00:0.82:ease_in_out")}
                    scaleY={curve("0.00:1.00:ease_in_out, 3.00:1.04:ease_in_out")}
                    skewY={curve("0.00:0:ease_in_out, 2.25:-4:ease_in_out, 3.00:-8:ease_in_out")}
                    transformOriginX="0"
                    transformOriginY="20"
                    d="M 210 -86 C 96 -156 -34 -182 -158 -142 C -262 -108 -334 -36 -350 54 C -306 180 -178 252 -26 248 C 126 244 224 154 234 20 C 238 -30 230 -62 210 -86 Z"
                    fill="url(#sclera_soft)"
