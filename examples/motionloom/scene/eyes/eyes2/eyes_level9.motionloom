              <Path id="closed_lash_line_level9"
                    d="M 202 -20 C 90 -72 -52 -82 -180 -42 C -266 -16 -328 30 -374 84"
                    stroke="#3F5877"
                    strokeWidth="8"
                    lineCap="round"
                    lineJoin="round"
