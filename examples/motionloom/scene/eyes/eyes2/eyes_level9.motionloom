              <Path id="closed_lash_soft_level9"
                    d="M 176 4 C 72 -32 -48 -40 -160 -8 C -236 14 -288 48 -326 86"
                    stroke="#B7C7C7"
                    strokeWidth="5"
                    lineCap="round"
                    fill="none"
                    opacity="0.62" />

              <Path id="closed_outer_spikes_level9"
                    d="M -350 70 C -404 86 -454 104 -510 108 M -334 94 C -382 130 -418 158 -456 192 M -304 112 C -340 154 -360 196 -364 234"
                    stroke="#3F5877"
                    strokeWidth="3"
                    lineCap="round"
                    fill="none"
                    opacity="0.82" />
            </Character>
          </Layer>
        </Sequence>
      </Track>
    </Timeline>
  </Scene>

  <Present from="eyes2_single_eye_gaze_blink_level9" />
</Graph>
